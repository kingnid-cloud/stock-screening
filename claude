// ── SCORING ENGINE ──────────────────────────────────────
const clamp = (v,a,b) => Math.min(b,Math.max(a,v));

function buildScores(d){
  const price=d.price, hi52=d.high52, lo52=d.low52, ma50=d.ma50, ma200=d.ma200;
  const chg=d.changePct, recMean=d.recMean, pt=d.ptMean, ptHi=d.ptHigh;
  const roe=d.roe, netMgn=d.netMgn, grossMgn=d.grossMgn;
  const revGrow=d.revGrow, epsGrow=d.epsGrow, dteq=d.dteq;
  const pe=d.pe, fpe=d.fpe;

  const pos52 = (price&&hi52&&lo52&&hi52>lo52)?(price-lo52)/(hi52-lo52):0.5;
  const analystUp = (price&&pt)?((pt-price)/price*100):null;
  const aboveMa50  = price&&ma50 ?price>ma50 :null;
  const aboveMa200 = price&&ma200?price>ma200:null;
  // Yahoo recMean: 1=strong buy, 5=strong sell → flip: higher=better
  const recS = recMean ? clamp(6-recMean,1,5) : 3;

  // 1-MONTH
  let s1m=5;
  if(pos52>0.75) s1m+=1.2; else if(pos52>0.55) s1m+=0.5; else if(pos52<0.25) s1m+=0.3; else s1m-=0.2;
  if(aboveMa50===true) s1m+=0.7; else if(aboveMa50===false) s1m-=0.7;
  if(aboveMa200===true) s1m+=0.4; else if(aboveMa200===false) s1m-=0.4;
  if(chg>3) s1m+=0.6; else if(chg>1) s1m+=0.3; else if(chg<-3) s1m-=0.6; else if(chg<-1) s1m-=0.2;
  if(recS>=4.5) s1m+=0.8; else if(recS>=4) s1m+=0.4; else if(recS<2) s1m-=1; else if(recS<2.5) s1m-=0.5;
  if(analystUp!=null){ if(analystUp>20) s1m+=0.4; else if(analystUp<0) s1m-=0.5; }
  s1m=clamp(Math.round(s1m*10)/10,1,10);

  // 1-YEAR
  let s1y=5;
  if(revGrow!=null){ if(revGrow>25) s1y+=1.8; else if(revGrow>12) s1y+=1; else if(revGrow>4) s1y+=0.5; else if(revGrow<0) s1y-=0.8; }
  if(epsGrow!=null){ if(epsGrow>25) s1y+=0.8; else if(epsGrow>10) s1y+=0.5; else if(epsGrow<-10) s1y-=0.8; else if(epsGrow<0) s1y-=0.3; }
  if(netMgn!=null){ if(netMgn>25) s1y+=0.7; else if(netMgn>12) s1y+=0.4; else if(netMgn<0) s1y-=0.8; }
  if(grossMgn!=null){ if(grossMgn>65) s1y+=0.4; else if(grossMgn>40) s1y+=0.2; }
  if(recS>=4.5) s1y+=1; else if(recS>=4) s1y+=0.5; else if(recS<2) s1y-=1; else if(recS<2.5) s1y-=0.5;
  if(analystUp!=null){ if(analystUp>40) s1y+=1.2; else if(analystUp>20) s1y+=0.7; else if(analystUp>5) s1y+=0.3; else if(analystUp<-5) s1y-=0.8; else if(analystUp<0) s1y-=0.4; }
  if(fpe!=null&&fpe>0){ if(fpe<15) s1y+=0.5; else if(fpe>60) s1y-=0.5; }
  s1y=clamp(Math.round(s1y*10)/10,1,10);

  // 5-YEAR
  let s5y=5;
  if(roe!=null){ if(roe>30) s5y+=1.8; else if(roe>20) s5y+=1.2; else if(roe>10) s5y+=0.6; else if(roe<0) s5y-=1; }
  if(grossMgn!=null){ if(grossMgn>70) s5y+=1.2; else if(grossMgn>50) s5y+=0.7; else if(grossMgn>35) s5y+=0.3; else if(grossMgn<15) s5y-=0.5; }
  if(netMgn!=null){ if(netMgn>30) s5y+=1; else if(netMgn>18) s5y+=0.6; else if(netMgn>5) s5y+=0.2; else if(netMgn<0) s5y-=1.2; }
  if(revGrow!=null){ if(revGrow>20) s5y+=0.8; else if(revGrow>8) s5y+=0.4; else if(revGrow<0) s5y-=0.5; }
  if(dteq!=null){ if(dteq<0.3) s5y+=0.6; else if(dteq<1) s5y+=0.2; else if(dteq>3) s5y-=0.6; }
  if(price&&ptHi){ const hu=((ptHi-price)/price*100); if(hu>100) s5y+=0.5; else if(hu>50) s5y+=0.3; else if(hu<10) s5y-=0.2; }
  s5y=clamp(Math.round(s5y*10)/10,1,10);

  const score=clamp(Math.round((s1m*0.2+s1y*0.5+s5y*0.3)*10)/10,1,10);
  return {score1m:s1m, score1y:s1y, score5y:s5y, score, analystUp, recS, pos52, aboveMa50, aboveMa200};
}

// ── API CALL ─────────────────────────────────────────────
async function apiFetch(symbols){
  const url = `/api/quotes?symbols=${symbols.join(",")}`;
  const r = await fetch(url, {signal: AbortSignal.timeout(120000)});
  const json = await r.json();
  return json.results || [];
}

// ── LOAD / REFRESH ────────────────────────────────────────
async function loadAll(){
  const btn=document.getElementById("refbtn");
  btn.disabled=true; btn.textContent="⟳ Loading…";
  showProg(true); setP(0);
  document.getElementById("sb-live").textContent="⟳ Fetching live data…";
  document.getElementById("sb-live").style.color="#fbbf24";

  const tickers = loadTickers();
  watchlist = tickers.map(t=>({symbol:t, name:t, price:null}));
  renderTable();

  // Fetch in batches of 10
  const BATCH=10;
  let done=0;
  for(let i=0;i<tickers.length;i+=BATCH){
    const batch=tickers.slice(i,i+BATCH);
    try{
      const results = await apiFetch(batch);
      results.forEach(d=>{
        const scores=buildScores(d);
        const idx=watchlist.findIndex(w=>w.symbol===d.symbol);
        const row={...d,...scores};
        if(idx>=0) watchlist[idx]=row; else watchlist.push(row);
      });
    }catch(e){ console.warn("batch error",e); }
    done+=batch.length;
    setP(Math.min(100,Math.round(done/tickers.length*100)));
    populateSectors(); renderTable(); renderSBar();
    if(i+BATCH<tickers.length) await sleep(200);
  }
  finish();
}

async function refreshAll(){
  const btn=document.getElementById("refbtn");
  btn.disabled=true; btn.textContent="⟳ Refreshing…";
  showProg(true); setP(0);
  const tickers=watchlist.map(w=>w.symbol);
  const BATCH=10; let done=0;
  for(let i=0;i<tickers.length;i+=BATCH){
    try{
      const results=await apiFetch(tickers.slice(i,i+BATCH));
      results.forEach(d=>{
        const scores=buildScores(d);
        const idx=watchlist.findIndex(w=>w.symbol===d.symbol);
        if(idx>=0) watchlist[idx]={...watchlist[idx],...d,...scores};
      });
    }catch(e){}
    done+=BATCH; setP(Math.min(100,Math.round(done/tickers.length*100)));
    renderTable(); renderSBar();
    if(i+BATCH<tickers.length) await sleep(200);
  }
  finish();
}

function finish(){
  const now=new Date();
  document.getElementById("hts").textContent=`● Live · Refreshed ${now.toLocaleTimeString()} · auto 90s`;
  document.getElementById("sb-live").textContent=`● LIVE · ${now.toLocaleTimeString()}`;
  document.getElementById("sb-live").style.color="#00ff88";
  showProg(false);
  const btn=document.getElementById("refbtn");
  btn.disabled=false; btn.textContent="↻ REFRESH ALL";
}

// ── ADD / REMOVE ──────────────────────────────────────────
async function addTicker(){
  const inp=document.getElementById("tickerinput");
  const sym=inp.value.trim().toUpperCase();
  if(!sym){ setMsg("Enter a ticker.","#f87171"); return; }
  if(watchlist.find(w=>w.symbol===sym)){ setMsg(sym+" already in watchlist.","#22d3ee"); inp.value=""; return; }
  setMsg(`⟳ Fetching ${sym}…`,"#06b6d4");
  document.getElementById("addbtn").disabled=true;
  try{
    const results=await apiFetch([sym]);
    if(!results.length||!results[0].price){ setMsg(`"${sym}" not found.`,"#f87171"); return; }
    const d=results[0]; const scores=buildScores(d);
    watchlist.push({...d,...scores});
    saveTickers(); populateSectors(); renderTable(); renderSBar();
    setMsg(`✓ ${d.name} added!`,"#00ff88"); inp.value="";
  }catch(e){ setMsg("Error: "+e.message,"#f87171"); }
  finally{ document.getElementById("addbtn").disabled=false; }
}

function removeTicker(sym){
  watchlist=watchlist.filter(w=>w.symbol!==sym);
  saveTickers(); populateSectors(); renderTable(); renderSBar();
}

async function quickAdd(sym){ document.getElementById("tickerinput").value=sym; await addTicker(); }

