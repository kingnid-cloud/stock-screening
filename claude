# ─────────────────────────────────────────────────────────

def fetch_quotes(symbols):
    """Fetch live quotes + fundamentals for a list of symbols."""
    results = []
    # yfinance batch download for price/day data
    try:
        tickers = yf.Tickers(" ".join(symbols))
    except Exception as e:
        print(f"  [error] yf.Tickers failed: {e}")
        return []

    for sym in symbols:
        try:
            t = tickers.tickers.get(sym)
            if not t:
                t = yf.Ticker(sym)
            info = t.fast_info  # fast — price, volume, 52w
            full = t.info       # full fundamentals

            price = getattr(info, "last_price", None) or full.get("regularMarketPrice") or full.get("currentPrice")
            prev  = getattr(info, "previous_close", None) or full.get("previousClose")
            chg_pct = ((price - prev) / prev * 100) if price and prev else None

            hi52 = getattr(info, "year_high", None) or full.get("fiftyTwoWeekHigh")
            lo52 = getattr(info, "year_low",  None) or full.get("fiftyTwoWeekLow")
            ma50  = full.get("fiftyDayAverage")
            ma200 = full.get("twoHundredDayAverage")

            rec_mean = full.get("recommendationMean")   # 1=strong buy … 5=strong sell
            pt_mean  = full.get("targetMeanPrice")
            pt_high  = full.get("targetHigh") or full.get("targetHighPrice")
            pt_low   = full.get("targetLow")  or full.get("targetLowPrice")
            n_analysts = full.get("numberOfAnalystOpinions", 0) or full.get("recommendationKey", 0)

            row = {
                "symbol":     sym,
                "name":       full.get("longName") or full.get("shortName") or sym,
                "sector":     full.get("sector") or full.get("industry") or "—",
                "currency":   full.get("currency", "USD"),
                "price":      round(price, 4) if price else None,
                "prevClose":  round(prev,  4) if prev  else None,
                "changePct":  round(chg_pct, 4) if chg_pct else None,
                "dayHigh":    full.get("dayHigh")  or full.get("regularMarketDayHigh"),
                "dayLow":     full.get("dayLow")   or full.get("regularMarketDayLow"),
                "volume":     full.get("volume")   or full.get("regularMarketVolume"),
                "high52":     round(hi52,  2) if hi52  else None,
                "low52":      round(lo52,  2) if lo52  else None,
                "ma50":       round(ma50,  2) if ma50  else None,
                "ma200":      round(ma200, 2) if ma200 else None,
                "mktCap":     full.get("marketCap"),
                "pe":         full.get("trailingPE"),
                "fpe":        full.get("forwardPE"),
                "pb":         full.get("priceToBook"),
                "eps":        full.get("trailingEps"),
                "epsF":       full.get("forwardEps"),
                "roe":        round(full.get("returnOnEquity",0)*100, 2) if full.get("returnOnEquity") else None,
                "roa":        round(full.get("returnOnAssets",0)*100, 2) if full.get("returnOnAssets") else None,
                "grossMgn":   round(full.get("grossMargins",0)*100, 2)  if full.get("grossMargins")   else None,
                "netMgn":     round(full.get("profitMargins",0)*100, 2) if full.get("profitMargins")  else None,
                "opMgn":      round(full.get("operatingMargins",0)*100,2) if full.get("operatingMargins") else None,
                "revGrow":    round(full.get("revenueGrowth",0)*100, 2) if full.get("revenueGrowth")  else None,
                "epsGrow":    round(full.get("earningsGrowth",0)*100,2) if full.get("earningsGrowth") else None,
                "dteq":       round(full.get("debtToEquity",0)/100, 3)  if full.get("debtToEquity")   else None,
                "currRatio":  full.get("currentRatio"),
                "divYield":   round(full.get("dividendYield",0)*100, 3) if full.get("dividendYield")  else None,
                "ptMean":     round(pt_mean, 2) if pt_mean else None,
                "ptHigh":     round(pt_high, 2) if pt_high else None,
                "ptLow":      round(pt_low,  2) if pt_low  else None,
                "recMean":    rec_mean,
                "analystN":   n_analysts if isinstance(n_analysts, int) else 0,
                "beta":       full.get("beta"),
                "shortPct":   round(full.get("shortPercentOfFloat",0)*100,2) if full.get("shortPercentOfFloat") else None,
            }
            results.append(row)
            print(f"  ✓ {sym:8s}  ${price:.2f}  {('+' if chg_pct and chg_pct>=0 else '')}{chg_pct:.2f}%" if price and chg_pct else f"  ✓ {sym}")
        except Exception as e:
            print(f"  ✗ {sym}: {e}")
            results.append({"symbol": sym, "error": str(e)})

    return results


# ─────────────────────────────────────────────────────────
#  HTTP SERVER
# ─────────────────────────────────────────────────────────

class Handler(http.server.BaseHTTPRequestHandler):

    def log_message(self, fmt, *args):
        pass  # suppress default access log

    def send_json(self, data, status=200):
        body = json.dumps(data).encode()
        self.send_response(status)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.send_header("Access-Control-Allow-Origin", "*")
        self.end_headers()
        self.wfile.write(body)

    def send_html(self, html):
        body = html.encode()
        self.send_response(200)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def do_GET(self):
        parsed = urllib.parse.urlparse(self.path)

        # ── API: /api/quotes?symbols=AAPL,MSFT,... ──
        if parsed.path == "/api/quotes":
            qs = urllib.parse.parse_qs(parsed.query)
            raw = qs.get("symbols", [""])[0]
            symbols = [s.strip().upper() for s in raw.split(",") if s.strip()]
            if not symbols:
                self.send_json({"error": "no symbols"}, 400)
                return
            print(f"\n[API] Fetching {len(symbols)} symbols: {', '.join(symbols[:8])}{'…' if len(symbols)>8 else ''}")
            t0 = time.time()
            data = fetch_quotes(symbols)
            print(f"[API] Done in {time.time()-t0:.1f}s")
            self.send_json({"results": data})

        # ── Dashboard HTML ──
        elif parsed.path in ("/", "/index.html"):
            self.send_html(DASHBOARD_HTML)

        else:
            self.send_response(404)
            self.end_headers()


