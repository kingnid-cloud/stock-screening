      ${mi("Upside to PT",d.analystUp!=null?(d.analystUp>=0?"+":"")+fmt(d.analystUp)+"%":"—",d.analystUp>15?"#00ff88":d.analystUp>0?"#a3e635":"#f87171")}
      ${mi("Trailing P/E",d.pe!=null&&d.pe>0?fmt(d.pe,1)+"x":"—",d.pe>0&&d.pe<20?"#a3e635":d.pe>60?"#fb923c":"#e2e8f0")}
      ${mi("Forward P/E",d.fpe!=null&&d.fpe>0?fmt(d.fpe,1)+"x":"—")}
      ${mi("P/Book",d.pb!=null?fmt(d.pb,2)+"x":"—")}
      ${mi("EPS TTM",d.eps?"$"+fmt(d.eps):"—")}${mi("EPS Fwd",d.epsF?"$"+fmt(d.epsF):"—")}
      ${mi("ROE",d.roe!=null?fmt(d.roe,1)+"%":"—",d.roe>25?"#22d3ee":d.roe>12?"#a3e635":d.roe<0?"#f87171":"#e2e8f0")}
      ${mi("Gross Margin",d.grossMgn!=null?fmt(d.grossMgn,1)+"%":"—",d.grossMgn>60?"#22d3ee":d.grossMgn>40?"#a3e635":"#e2e8f0")}
      ${mi("Net Margin",d.netMgn!=null?fmt(d.netMgn,1)+"%":"—",d.netMgn>20?"#22d3ee":d.netMgn>0?"#a3e635":"#f87171")}
      ${mi("Rev Growth",d.revGrow!=null?(d.revGrow>=0?"+":"")+fmt(d.revGrow,1)+"%":"—",d.revGrow>15?"#22d3ee":d.revGrow>0?"#a3e635":"#f87171")}
      ${mi("EPS Growth",d.epsGrow!=null?(d.epsGrow>=0?"+":"")+fmt(d.epsGrow,1)+"%":"—")}
      ${mi("Debt/Equity",d.dteq!=null?fmt(d.dteq,2)+"x":"—",d.dteq<0.5?"#a3e635":d.dteq>3?"#f87171":"#e2e8f0")}
      ${mi("Beta",d.beta!=null?fmt(d.beta,2):"—")}
      ${mi("Short %",d.shortPct!=null?fmt(d.shortPct,1)+"%":"—",d.shortPct>10?"#f87171":d.shortPct>5?"#fb923c":"#e2e8f0")}
      ${mi("Div Yield",d.divYield!=null?fmt(d.divYield,2)+"%":"—","#a3e635")}
      ${mi("Mkt Cap",fmtCap(d.mktCap))}
    </div></div>
    <div class="ms"><h3>SIGNAL SUMMARY</h3><div class="sg">
      ${si("Composite",d.score+"/10",sc(d.score))}${si("1-Month",d.score1m+"/10",sc(d.score1m))}
      ${si("1-Year",d.score1y+"/10",sc(d.score1y))}${si("5-Year",d.score5y+"/10",sc(d.score5y))}
      ${si("Verdict",vd(d.score),sc(d.score))}${si("Analyst Rating",recTxt,d.recMean<2?"#00ff88":d.recMean<3?"#22d3ee":d.recMean>4?"#f87171":"#fbbf24")}
      ${si("Above 50MA",d.price&&d.ma50?(d.price>d.ma50?"YES ▲":"NO ▼"):"—",d.price&&d.ma50?(d.price>d.ma50?"#22d3ee":"#f87171"):"#475569")}
      ${si("Above 200MA",d.price&&d.ma200?(d.price>d.ma200?"YES ▲":"NO ▼"):"—",d.price&&d.ma200?(d.price>d.ma200?"#22d3ee":"#f87171"):"#475569")}
      ${si("52W Position",d.pos52!=null?((d.pos52*100).toFixed(0)+"% of range"):"—",d.pos52>0.7?"#a3e635":d.pos52<0.3?"#22d3ee":"#fbbf24")}
    </div></div>
  </div>`;
}

function pc(label,score,target,why,sub){
  if(score==null) return `<div class="pc"><div class="pc-lbl">${label}</div><div style="color:#334155;padding:20px 0">No data</div></div>`;
  const sc=score>=8.5?"#00ff88":score>=7.5?"#22d3ee":score>=6.5?"#a3e635":score>=5.5?"#fbbf24":score>=4?"#fb923c":"#f87171";
  const vd=score>=8.5?"STRONG BUY":score>=7.5?"BUY":score>=6.5?"WATCH+":score>=5.5?"WATCH":score>=4?"RISKY":"AVOID";
  return `<div class="pc" style="border:1px solid ${sc}55"><div class="pc-lbl">${label}</div><div class="pc-num" style="color:${sc}">${score}</div><div class="pc-verd" style="color:${sc}">${vd}</div><div class="pc-tgt">Est. target: <strong style="color:#a3e635">${target}</strong></div><div class="pc-why">${why}</div><div style="font-size:9px;color:#334155;margin-top:5px">${sub}</div></div>`;
}
function mi(k,v,c="#e2e8f0"){ return `<div class="mi"><div class="mi-k">${k}</div><div class="mi-v" style="color:${c}">${v}</div></div>`; }
function si(k,v,c="#e2e8f0"){ return `<div class="si"><span class="si-k">${k}</span><span class="si-v" style="color:${c}">${v}</span></div>`; }

function overlayClick(e){ if(e.target===document.getElementById("modal-overlay"))closeModal(); }
function closeModal(){ document.getElementById("modal-overlay").classList.remove("open"); }

// ── UTILS ─────────────────────────────────────────────────
const fmt     = (n,d=2)=>n!=null&&!isNaN(n)?Number(n).toLocaleString(undefined,{minimumFractionDigits:d,maximumFractionDigits:d}):"—";
const fmtCap  = n=>!n?"—":n>=1e12?"$"+(n/1e12).toFixed(2)+"T":n>=1e9?"$"+(n/1e9).toFixed(2)+"B":n>=1e6?"$"+(n/1e6).toFixed(1)+"M":"$"+n.toLocaleString();
const sleep   = ms=>new Promise(r=>setTimeout(r,ms));
const showProg= v=>document.getElementById("progbar").style.display=v?"block":"none";
const setP    = p=>document.getElementById("progfill").style.width=p+"%";
function setMsg(t,c="#fbbf24"){ const el=document.getElementById("addmsg"); el.textContent=t; el.style.color=c; if(t) setTimeout(()=>{if(el.textContent===t)el.textContent=""},5000); }

setInterval(refreshAll, 90000);
window.onload=()=>{
  document.getElementById("hdate").textContent=new Date().toLocaleDateString("en-US",{weekday:"short",year:"numeric",month:"short",day:"numeric"}).toUpperCase();
  renderTable();
  loadAll();
};
</script>
</body>
